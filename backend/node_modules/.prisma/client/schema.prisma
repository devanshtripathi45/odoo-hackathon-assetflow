generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
}

model User {
  id               String      @id @default(uuid())
  name             String
  email            String      @unique
  password         String
  role             Role        @default(EMPLOYEE)
  status           Status      @default(ACTIVE)
  departmentId     String?
  department       Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  headOfDepartments Department[]        @relation("DepartmentHead")
  createdAssets     Asset[]             @relation("AssetCreatedBy")
  allocationsMade   AllocationHistory[] @relation("AllocatedBy")
  transferRequests  TransferRequest[]   @relation("TransferRequester")
  bookings          Booking[]
}

model Department {
  id        String       @id @default(uuid())
  name      String       @unique
  status    Status       @default(ACTIVE)
  headId    String?
  head      User?        @relation("DepartmentHead", fields: [headId], references: [id])
  parentId  String?
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  members   User[]       @relation("DepartmentMembers")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model AssetCategory {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  customFields Json     @default("[]")
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assets       Asset[]
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

model Asset {
  id              String         @id @default(uuid())
  assetTag        String         @unique
  name            String
  categoryId      String
  category        AssetCategory  @relation(fields: [categoryId], references: [id])
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Float?
  condition       AssetCondition @default(NEW)
  location        String?
  isBookable      Boolean        @default(false)
  status          AssetStatus    @default(AVAILABLE)
  photoPath       String?
  documentPath    String?
  createdById     String
  createdBy       User           @relation("AssetCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  allocationHistory  AllocationHistory[]
  maintenanceHistory MaintenanceHistory[]
  transferRequests   TransferRequest[]
  bookings           Booking[]
}

model AllocationHistory {
  id                 String    @id @default(uuid())
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id])
  allocatedToType    String? // "EMPLOYEE" or "DEPARTMENT"
  allocatedToId      String?
  allocatedById      String?
  allocator          User?     @relation("AllocatedBy", fields: [allocatedById], references: [id])
  expectedReturnDate DateTime?
  returnedDate       DateTime?
  action             String?
  notes              String?
  createdAt          DateTime  @default(now())
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  RE_ALLOCATED
}

model TransferRequest {
  id                String         @id @default(uuid())
  assetId           String
  asset             Asset          @relation(fields: [assetId], references: [id])
  currentHolderId   String?
  currentHolderType String?
  requesterId       String
  requester         User           @relation("TransferRequester", fields: [requesterId], references: [id])
  reason            String?
  status            TransferStatus @default(REQUESTED)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model MaintenanceHistory {
  id          String    @id @default(uuid())
  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id])
  type        String?
  description String?
  cost        Float?
  performedBy String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
}

model Booking {
  id           String   @id @default(uuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  date         DateTime
  startTime    DateTime
  endTime      DateTime
  purpose      String?
  isDepartment Boolean  @default(false)
  isCancelled  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
